// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum StorageType {
  local
  oss
  s3
}

enum MediaType {
  image
  video
  audio
  document
  other
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VIEWER)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  apiKeys   ApiKey[]

  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  level       Int        @default(1)
  path        String     @default("/")
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  articles    Article[]

  @@map("categories")
}

model Tag {
  id           String       @id @default(uuid())
  name         String       @unique
  slug         String       @unique
  description  String?
  articleCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  articles     ArticleTag[]

  @@map("tags")
}

model Article {
  id                 String       @id @default(uuid())
  title              String
  slug               String       @unique
  summary            String?      @db.Text
  content            String?      @db.Text
  coverImage         String?
  isPublished        Boolean      @default(false)
  publishedAt        DateTime?
  seoTitle           String?
  seoDescription     String?      @db.Text
  locale             String       @default("zh-CN") // 语言标识: zh-CN, en-US
  translationGroupId String?      // 翻译组ID，同组文章互为翻译版本
  categoryId         String?
  category           Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags               ArticleTag[]
  viewCount          Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("articles")
  @@index([isPublished])
  @@index([slug])
  @@index([translationGroupId])
  @@index([locale])
  @@index([categoryId])
}

model ArticleTag {
  id        String  @id @default(uuid())
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@map("article_tags")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  techStack   String[] // PostgreSQL 数组类型
  coverImage  String?
  link        String?
  githubUrl   String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Media {
  id           String      @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  storageType  StorageType @default(local)
  storagePath  String
  mediaType    MediaType   @default(other)
  width        Int?
  height       Int?
  alt          String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("media")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String    // Key 名称，方便用户识别
  keyHash     String    @unique // 存储 hash 后的 key
  keyPrefix   String    // 存储 key 前缀用于展示（如 "sk-xxxx"）
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt  DateTime?
  isRevoked   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("api_keys")
  @@index([userId])
}

model SiteConfig {
  id             String   @id @default(uuid())
  title          String   @default("My Blog")
  description    String?  @db.Text
  keywords       String?
  logo           String?
  favicon        String?
  icp            String?  // ICP 备案号
  gongan         String?  // 公安备案号
  copyright      String?
  analytics         String?  @db.Text // 统计代码（旧字段，保留兼容）
  analyticsGoogle   String?  // Google Analytics Measurement ID，如 G-XXXXXXXXXX
  analyticsBaidu    String?  // 百度统计 site key，如 xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  ownerName          String?
  ownerAvatar        String?
  ownerBio           String?  @db.Text
  ownerEmail         String?
  ownerTechStack     String[] @default([])
  yearsOfExperience  Int?
  openSourceCount    Int?
  talkCount          Int?
  socialGithub       String?
  socialTwitter      String?
  socialLinkedin     String?
  socialWeibo        String?
  aboutImage1        String?  // About 页面左上图片 URL
  aboutImage2        String?  // About 页面右下图片 URL
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("site_config")
}

model TimelineEntry {
  id        String   @id @default(uuid())
  year      String
  titleZh   String   @db.VarChar(100)
  titleEn   String   @db.VarChar(100)
  descZh    String   @db.VarChar(500)
  descEn    String   @db.VarChar(500)
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isVisible])
  @@map("timeline_entries")
}
